# =============================================
# AIOps-Pilot 环境变量配置模板
# 复制这个文件为 .env，然后填入真实的值
# .env 文件不要提交到 git（已在 .gitignore 里）
# =============================================

# 阿里云 DashScope API Key（必填）
# 获取地址：https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=your-api-key-here

# LLM 模型（默认 qwen-plus，可改为 qwen-max 等）
DASHSCOPE_MODEL=qwen-plus
RAG_MODEL=qwen-plus

# Embedding 模型（向量化用）
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4

# Milvus 向量数据库地址（Docker 本地运行用默认值即可）
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_TIMEOUT=10000

# 文档分块配置
CHUNK_MAX_SIZE=1000
CHUNK_OVERLAP=200
